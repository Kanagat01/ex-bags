# Django
SECRET_KEY=your-secret-key-here
DJANGO_SETTINGS_MODULE=config.settings.local

# База данных
POSTGRES_DB=exbags
POSTGRES_USER=exbags
POSTGRES_PASSWORD=exbags_password
DATABASE_URL=postgres://exbags:exbags_password@db:5432/exbags

# Redis / Celery
REDIS_URL=redis://redis:6379/0

# Фронтенд (для генерации ссылок в SMS)
FRONTEND_URL=http://localhost:3000

# SMS 
SMS_INT_API_KEY=твой-api-ключ
SMS_INT_SIGN=НазваниеОтправителя

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=False
EMAIL_USE_SSL=True
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@ex-bags.ru

